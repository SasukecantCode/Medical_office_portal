# Copy to .env and adjust as needed
APP_NAME="Health Office Portal API"
ENVIRONMENT=dev
CORS_ORIGINS="*"

# SQLite default (file will be created under backend/)
DATABASE_URL="sqlite:///./portal.db"

# Local attachments storage directory (relative to backend/)
UPLOADS_DIR="./uploads"

# Google Cloud Storage (Document Vault)
GCS_BUCKET_NAME="medical-office-hr-documents"
DOCUMENT_MAX_SIZE_BYTES=10485760
