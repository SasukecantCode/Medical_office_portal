{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DMO-Namsai-Portal",
  "version": "0.4.0",
  "identifier": "com.dmo.namsai-portal",
  "build": {
    "frontendDist": "../src/dist",
    "beforeDevCommand": "npm --prefix src run dev",
    "beforeBuildCommand": "npm --prefix src install && npm --prefix src run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DMO Namsai — Data Portal",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/medical-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
